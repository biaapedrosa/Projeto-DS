generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

  model Patient {
    id               Int      @id @default(autoincrement())
    name             String   @db.VarChar(100)
    cpf              String   @unique @db.VarChar(11)
    email            String   @unique @db.VarChar(255)
    phone            String   @unique
    address          String?  @db.VarChar(255)
    birthDate        DateTime
    height           String[] 
    weight           String[] 
    comorbidities    String[] 
    phisicalActivity Boolean? 
    allergies        String[] 
    intolerances     String[] 
    medications      String[] 

    Plans MealPlan[] 
    @@map ("paciente")
  } 
  model MealPlan {
    ...
  }
